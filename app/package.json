{
  "name": "archestra-ai-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "docs:pull": "node scripts/pull-docs.js",
    "build": "pnpm docs:pull && next build",
    "build:check": "pnpm docs:pull && next build",
    "dev": "next dev -p 3001",
    "start": "next start",
    "test": "vitest",
    "knip": "knip",
    "prettier": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "catalog:evaluate": "npx tsx app/mcp-catalog/scripts/evaluate-catalog.ts",
    "catalog:validate": "npx tsx app/mcp-catalog/scripts/validate-catalog.ts",
    "openapi:generate": "npx tsx app/mcp-catalog/scripts/generate-openapi-schema.ts && pnpm prettier --write app/mcp-catalog/api/docs/openapi.json",
    "db:push": "npx drizzle-kit push",
    "db:studio": "npx drizzle-kit studio",
    "slack:sync": "npx tsx app/community-stream/scripts/slack-sync.ts",
    "codegen:all": "pnpm openapi:generate",
    "check:ci": "pnpm prettier --check . && pnpm knip && pnpm test && pnpm typecheck && pnpm build:check && pnpm catalog:validate",
    "ci:check": "pnpm check:ci"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@neondatabase/serverless": "^1.1.0",
    "@next/third-parties": "^16.2.6",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/rest": "^22.0.1",
    "@radix-ui/react-slot": "1.2.4",
    "@slack/web-api": "^7.16.0",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.16.0",
    "mermaid": "^11.15.0",
    "next": "16.2.6",
    "posthog-js": "^1.374.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "reading-time": "^1.5.0",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "swagger-ui-react": "^5.32.6",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "^2.1.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19",
    "@types/swagger-ui-react": "^5.18.0",
    "@vitejs/plugin-react": "^6.0.2",
    "csv-parse": "^6.2.1",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.1.1",
    "knip": "^6.14.1",
    "postcss": "^8.5",
    "postcss-load-config": "^6.0.1",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.22.3",
    "typescript": "^6",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "packageManager": "pnpm@11.4.0"
}
